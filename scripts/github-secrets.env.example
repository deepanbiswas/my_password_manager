# Copy to scripts/github-secrets.env (gitignored) and fill in. Then:
#   ./scripts/push-github-secrets.sh scripts/github-secrets.env
#
# Use AZURE_CREDENTIALS_FILE pointing at JSON from `az ad sp create-for-rbac --sdk-auth` (or equivalent).
# Use SSH_PRIVATE_KEY_FILE pointing at the private key matching Terraform's public key.

AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_CREDENTIALS_FILE=
DOMAIN=https://your-hostname.example
SSH_PRIVATE_KEY_FILE=
VM_USERNAME=
