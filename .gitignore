.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.iml

# Temporary files
tmp/
temp/
*.tmp

# Docker volumes (if any)
docker-volumes/

# SSH keys (if stored locally)
*.pem
*.key
id_rsa
id_rsa.pub

# Rclone config (contains credentials)
.rclone.conf

